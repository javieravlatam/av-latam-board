<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<script>
  /* AV Auth Guard · sesión activa mientras la pestaña esté abierta */
  (function(){
    if(sessionStorage.getItem('av_auth')!=='7cd4374e16e78510de24a08115c3b44f6d0d72762d41054e6ef8fa0cb5e0c45b')
      window.location.replace('index.html');
    if(sessionStorage.getItem('av_role')==='jefe')
      window.location.replace('Panel_Jefes_Index.html');
  })();
</script>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panel Comercial · Chile · AV Latam 2026</title>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<link rel="stylesheet" href="design-system/formato-javier-tokens.css"
      onerror="console.error('DS tokens missing')">
<link rel="stylesheet" href="design-system/formato-javier-base.css">
<link rel="stylesheet" href="design-system/formato-javier-components.css">
<link rel="stylesheet" href="design-system/formato-javier-executive.css">
<link rel="stylesheet" href="design-system/formato-javier-motion.css">
<link rel="stylesheet" href="design-system/formato-javier-utilities.css">
<link rel="stylesheet" href="design-system/domains/formato-javier-board.css">
<script src="js/av-chart-colors.js"></script>
<!-- FORMATO JAVIER v1.1 Phosphor Icons Regular -->
<link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css">
<style>

:root { --red2: #C0392B; /* panel token — no DS equiv */ }

/* ── HEADER ─────────────────────────────────────────────────── */
.hdr{background:var(--bg);border-bottom:1px solid var(--border);
  padding:14px 28px;display:flex;align-items:center;justify-content:space-between;
  position:sticky;top:0;z-index:100;}
.hdr::before{content:'';position:absolute;bottom:0;left:0;width:120px;height:2px;
  background:linear-gradient(90deg,var(--positive),transparent);}
.hdr-l{display:flex;align-items:center;gap:13px}
.logo{width:38px;height:38px;background:var(--positive);border-radius:8px;
  display:flex;align-items:center;justify-content:center;
  font-family:'Bebas Neue';font-size:17px;color:var(--bg)}
.htitle{font-family:'Bebas Neue';font-size:20px;letter-spacing:2px;color:var(--positive)}
.hsub{font-size:9px;color:var(--text-muted);letter-spacing:1.5px;text-transform:uppercase}
.hcorte{font-family:'DM Mono';font-size:10px;color:var(--text-dim);text-align:right}
.hcorte b{color:var(--positive)}
.hnav{display:flex;gap:6px;flex-wrap:wrap}

/* ── LAYOUT ─────────────────────────────────────────────────── */
.page{max-width:1440px;margin:0 auto;padding:24px 32px 60px}

/* ── ZONE HEADERS ────────────────────────────────────────────── */
.zona-hdr{display:flex;align-items:baseline;gap:10px;margin:0 0 14px;}
.zona-tag{font-family:'DM Mono';font-size:9px;color:var(--text-muted);
  letter-spacing:2px;text-transform:uppercase;
  background:var(--surface-2);border:1px solid var(--border-dim);
  border-radius:3px;padding:2px 7px;white-space:nowrap;}
.zona-title{font-family:'Bebas Neue';font-size:15px;letter-spacing:4px;color:var(--positive);}
.zona-title-risk{color:var(--danger);}

/* ── KPI GRID ───────────────────────────────────────────────── */
.kpi-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:12px;margin-bottom:24px;}
.kpi{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:14px 16px;position:relative;overflow:hidden}
.kpi::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--positive)}
.kpi.av-text-warning::after{background:var(--warning)}.kpi.av-text-danger::after{background:var(--danger)}
.kpi-danger{background:rgba(231,76,60,0.04);border-color:rgba(231,76,60,0.25);border-left:3px solid var(--danger);}
.kpi-danger::after{background:var(--danger);}
.klbl{font-size:8px;color:var(--text-muted);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:5px}
.kval{font-family:'Bebas Neue';font-size:26px;line-height:1}
.kval-hero{font-size:40px;}
.kval-danger{font-size:32px;color:var(--danger);}
.ksub{font-family:'DM Mono';font-size:9px;color:var(--text-muted);margin-top:3px}

/* ── SEMÁFORO ────────────────────────────────────────────────── */
.sema-list{display:flex;flex-direction:column;gap:0}
.sema-row{display:flex;align-items:center;gap:12px;padding:11px 10px;
  border-bottom:1px solid var(--border-dim);transition:background .15s}
.sema-row:last-child{border-bottom:none}
.sema-row:hover{background:var(--surface-2)}
.sema-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0}
.sd-ok{background:var(--positive);box-shadow:0 0 7px rgba(122,182,72,0.5)}
.sd-am{background:var(--warning)}.sd-rd{background:var(--danger)}.sd-rd2{background:var(--red2)}
.sema-info{flex:1;min-width:0}
.sema-name{font-weight:700;font-size:13px}
.sema-sub{font-size:10px;color:var(--text-muted);margin-top:1px}
.sema-pct{font-family:'Bebas Neue';font-size:22px;flex-shrink:0}

/* ── BARRAS MENSUALES ────────────────────────────────────────── */
.mes-bars{display:flex;flex-direction:column;gap:8px;margin-top:4px}
.mes-row{display:flex;align-items:center;gap:8px}
.mes-lbl{font-size:11px;color:var(--text-dim);width:58px;flex-shrink:0}
.mes-bar-wrap{flex:1;background:var(--surface-3);border-radius:3px;height:8px;overflow:hidden}
.mes-bar-fill{height:100%;border-radius:3px}
.mes-pct{font-family:'DM Mono';font-size:10px;width:46px;text-align:right;flex-shrink:0}

/* ── TABLA ───────────────────────────────────────────────────── */
.av-table thead th{font-size:8px;letter-spacing:1.2px;padding:0 7px 8px;border-bottom:1px solid var(--border-dim);font-weight:500;text-align:right}
.av-table thead th:first-child{text-align:left}
.av-table tbody tr:hover{background:var(--surface-2)}
.av-table td{padding:9px 7px}
.av-table tfoot tr{background:var(--surface-3);border-top:1px solid var(--border)}
.av-table tfoot td{padding:9px 7px;font-weight:700;font-size:11px}

/* ── BADGES DE TABLA ─────────────────────────────────────────── */
.pb{display:inline-block;padding:1px 6px;border-radius:3px;font-size:8px;font-weight:700}
.pb-ok{background:rgba(122,182,72,0.15);color:var(--positive)}
.pb-am{background:rgba(245,166,35,0.15);color:var(--warning)}
.pb-rd{background:rgba(231,76,60,0.15);color:var(--danger)}
.mb{background:var(--surface-3);border-radius:2px;height:3px;margin-top:3px;overflow:hidden}
.mbf{height:100%;border-radius:2px}

/* ── MARGEN STRIP ────────────────────────────────────────────── */
.margen-strip{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;
  background:var(--surface-2);border-radius:8px;padding:12px;margin-top:8px}
.mg-item{text-align:center}
.mg-val{font-family:'DM Mono';font-size:15px;font-weight:700}
.mg-lbl{font-size:9px;color:var(--text-muted);margin-top:2px;text-transform:uppercase;letter-spacing:1px}

/* ── EXEC ACTION ZONE ────────────────────────────────────────── */
.exec-primary{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;}
.exec-primary > *,.exec-secondary > *{margin-bottom:0;}
.exec-secondary{display:grid;grid-template-columns:1fr 1fr;gap:10px;
  opacity:0.55;transition:opacity .2s;}
.exec-secondary:hover{opacity:1;}

/* ── CxC SUMMARY BAR ─────────────────────────────────────────── */
.cxc-summary-bar{background:rgba(231,76,60,0.03);border:1px solid rgba(231,76,60,0.18);
  border-left:3px solid var(--danger);border-radius:0 8px 8px 0;
  padding:12px 20px;margin-bottom:16px;display:flex;align-items:center;gap:32px;}

/* ── SECTION TITLE ───────────────────────────────────────────── */
.sec{font-family:'Bebas Neue';font-size:14px;letter-spacing:3px;color:var(--positive);
  border-left:3px solid var(--positive);padding-left:10px;margin:22px 0 14px;
  display:flex;align-items:center;gap:8px}
.sec span{font-family:'DM Mono';font-size:9px;color:var(--text-muted);font-weight:400}

/* ── CHARTS ──────────────────────────────────────────────────── */
.ch{position:relative}.ch-xl{height:280px}.ch-lg{height:260px}.ch-md{height:200px}

/* ── FOOTER ──────────────────────────────────────────────────── */
.ftr{border-top:1px solid var(--border-dim);padding:14px 28px;
  display:flex;justify-content:space-between;align-items:center;margin-top:20px;
  font-size:9px;color:var(--text-muted)}
.npills{display:flex;gap:7px}
.sep{margin:28px 0;border:none;border-top:1px solid var(--border-dim)}

@media(max-width:960px){.av-grid-2,.av-grid-3,.kpi-grid,.exec-primary,.exec-secondary{grid-template-columns:1fr}}

.btn-logout{background:transparent;border:1px solid rgba(231,76,60,0.40);border-radius:6px;
  padding:5px 12px;font-size:11px;color:var(--danger);cursor:pointer;
  font-family:'DM Sans',sans-serif;letter-spacing:.3px;transition:all .2s;}
.btn-logout:hover{background:rgba(231,76,60,0.10);}

</style>
</head>
<body>

<header class="hdr">
  <div class="hdr-l">
    <div class="logo">CL</div>
    <div>
      <div class="htitle">Panel Comercial · 🇨🇱 Chile</div>
      <div id="av-cl-hsub" class="hsub">Jefe Comercial · Ene–May 2026</div>
    </div>
  </div>
  <div class="hnav">
    <a href="dashboard.html" class="av-nav-item">← Países</a>
    <a href="Panel_General_AV_2026.html" class="av-nav-item"><i class="ph-globe" aria-hidden="true"></i> General</a>
    <a href="Panel_Chile_AV_2026.html" class="av-nav-item active">🇨🇱 Chile</a>
    <a href="Panel_Peru_AV_2026.html" class="av-nav-item">🇵🇪 Perú</a>
    <a href="Panel_Ecuador_AV_2026.html" class="av-nav-item">🇪🇨 Ecuador</a>
  </div>
  <div id="av-cl-hdr-corte" class="hcorte">
    <div>Corte ventas <b>—</b> · CxC <b>—</b></div>
    <div style="font-size:8px;margin-top:1px;">TC = 950 CLP/USD · Ppto anual CLP 861,321,350</div>
  </div>
  <button class="btn-logout" onclick="cerrarSesion()"><i class="ph-lock" aria-hidden="true"></i> Cambiar acceso</button>
</header>

<div class="page">

  <!-- ════════════════════════════════════════════════
       ZONA 1 · STATUS
  ═════════════════════════════════════════════════ -->
  <div class="zona-hdr">
    <div class="zona-tag">Zona 1</div>
    <div class="zona-title">Status</div>
  </div>

  <div class="kpi-grid">
    <!-- HERO: YTD Chile — 2fr width, 40px value -->
    <div class="kpi">
      <div id="av-cl-kpi-ytd-lbl" class="klbl">YTD Chile 5m</div>
      <div id="av-cl-kpi-ytd-val" class="kval kval-hero av-text-positive">—</div>
      <div id="av-cl-kpi-ytd-sub" class="ksub">—</div>
      <span id="av-cl-kpi-ytd-badge" class="av-badge av-text-positive">—</span>
    </div>
    <!-- DANGER KPI: MN Real Chile — borde semántico, fondo sutil, valor 32px -->
    <div class="kpi kpi-danger">
      <div class="klbl">MN Real Chile</div>
      <div id="av-cl-kpi-mn-val" class="kval kval-danger">17.9%</div>
      <div class="ksub">Meta corporativa: 25%</div>
      <span class="av-badge alert">Gap –7.1pp · 2 ultimátum</span>
    </div>
    <!-- Secondary: YTD USD -->
    <div class="kpi">
      <div class="klbl">YTD en USD</div>
      <div id="av-cl-kpi-usd-val" class="kval av-text-positive">—</div>
      <div id="av-cl-kpi-usd-sub" class="ksub">—</div>
      <span id="av-cl-kpi-usd-badge" class="av-badge av-text-positive">—</span>
    </div>
    <!-- Secondary: Mayo Parcial -->
    <div class="kpi av-text-warning">
      <div id="av-cl-kpi-abr-lbl" class="klbl">Mayo Parcial</div>
      <div id="av-cl-kpi-abr-val" class="kval av-text-warning">—</div>
      <div id="av-cl-kpi-abr-sub" class="ksub">—</div>
      <span id="av-cl-kpi-abr-badge" class="av-badge warn">—</span>
    </div>
  </div>

  <hr class="sep">

  <!-- ════════════════════════════════════════════════
       ZONA 2 · TENDENCIA
  ═════════════════════════════════════════════════ -->
  <div class="zona-hdr">
    <div class="zona-tag">Zona 2</div>
    <div class="zona-title">Tendencia</div>
  </div>

  <div class="av-grid-2" style="margin-bottom:15px;">
    <div class="av-panel">
      <div class="av-panel__header">VENTA MENSUAL APILADA · CHILE <span class="av-badge">CLP millones · por RTC</span></div>
      <div class="ch ch-lg"><canvas id="cStack"></canvas></div>
    </div>
    <div class="av-panel">
      <div class="av-panel__header">CURVA ACUMULADA CHILE 2026 <span class="av-badge">CLP · ppto vs real · 12 meses</span></div>
      <div class="ch ch-lg"><canvas id="cCurva"></canvas></div>
    </div>
  </div>

  <hr class="sep">

  <!-- ════════════════════════════════════════════════
       ZONA 3 · CAUSA
  ═════════════════════════════════════════════════ -->
  <div class="zona-hdr">
    <div class="zona-tag">Zona 3</div>
    <div class="zona-title">Causa</div>
  </div>

  <div class="av-grid-2" style="margin-bottom:15px;align-items:start;">

    <div class="av-panel">
      <div class="av-panel__header">SEMÁFORO RTC · CHILE <span id="av-cl-sema-tag" class="av-badge">MN REAL</span></div>
      <div class="sema-list">

        <div class="sema-row">
          <span style="font-size:15px;">⭐</span>
          <div class="sema-info">
            <div class="sema-name">J. Caroca <span style="font-size:10px;color:var(--positive);font-weight:400;">MN 39.2%</span></div>
            <div class="sema-sub">YTD CLP 63.3M · T1 161% ppto · Abr +10.2M · Referente del grupo</div>
          </div>
          <div class="sema-pct av-text-positive">161.0%</div>
          <div class="sema-dot sd-ok"></div>
        </div>

        <div class="sema-row">
          <span style="font-size:15px;"><i class="ph-warning" style="color:var(--warning)" aria-hidden="true"></i></span>
          <div class="sema-info">
            <div class="sema-name">P. Laratro <span style="font-size:10px;color:var(--warning);font-weight:400;">MN 19.6%</span></div>
            <div class="sema-sub">YTD CLP 61.2M · T1 97.8% · Abr +8.3M · Estructura alta</div>
          </div>
          <div class="sema-pct av-text-warning">97.8%</div>
          <div class="sema-dot sd-am"></div>
        </div>

        <div class="sema-row">
          <span style="font-size:15px;"><i class="ph-warning" style="color:var(--warning)" aria-hidden="true"></i></span>
          <div class="sema-info">
            <div class="sema-name">R. Encina <span style="font-size:10px;color:var(--warning);font-weight:400;">MN 21.9%</span></div>
            <div class="sema-sub">YTD CLP 29.4M · T1 94.5% · Abr +1.8M · Camioneta desde Mayo</div>
          </div>
          <div class="sema-pct av-text-warning">94.5%</div>
          <div class="sema-dot sd-am"></div>
        </div>

        <div class="sema-row">
          <span style="font-size:15px;"><i class="ph-circle ph-fill" style="color:var(--danger);font-size:10px" aria-hidden="true"></i></span>
          <div class="sema-info">
            <div class="sema-name">F. Velásquez <span style="font-size:10px;color:var(--danger);font-weight:400;">MN 2.8% · ULTIMÁTUM</span></div>
            <div class="sema-sub">YTD CLP 32.7M · T1 90.1% · Abr +3.1M · Ppto anual CLP 253.9M</div>
          </div>
          <div class="sema-pct av-text-danger">90.1%</div>
          <div class="sema-dot sd-rd"></div>
        </div>

        <div class="sema-row">
          <span style="font-size:15px;"><i class="ph-x-circle" style="color:var(--danger)" aria-hidden="true"></i></span>
          <div class="sema-info">
            <div class="sema-name">I. Veverka <span style="font-size:10px;color:var(--red2);font-weight:400;">MN –28.7% · INVIABLE</span></div>
            <div class="sema-sub">YTD CLP 8.8M · T1 48.9% · Zona en evaluación cierre Q3</div>
          </div>
          <div class="sema-pct av-text-danger">48.9%</div>
          <div class="sema-dot sd-rd2"></div>
        </div>

        <div class="sema-row">
          <span style="font-size:15px;"><i class="ph-check-circle" style="color:var(--positive)" aria-hidden="true"></i></span>
          <div class="sema-info">
            <div class="sema-name">V. Muñoz</div>
            <div class="sema-sub">YTD CLP 4.2M · T1 117.7% · Por encima de objetivo</div>
          </div>
          <div class="sema-pct av-text-positive">117.7%</div>
          <div class="sema-dot sd-ok"></div>
        </div>

      </div>
    </div>

    <!-- Barras mensuales + margen strip -->
    <div class="av-panel">
      <div class="av-panel__header">CUMPLIMIENTO MENSUAL <span class="av-badge">CLP · Real vs Ppto</span></div>
      <div id="av-cl-mes-container" class="mes-bars" style="margin-bottom:14px;"></div>
      <div id="av-cl-margen-strip" class="margen-strip"></div>
      <div id="av-cl-mes-acum" style="font-size:9px;color:var(--text-muted);margin-top:6px;">—</div>
    </div>
  </div>

  <!-- Desempeño por RTC -->
  <div class="sec">Desempeño por RTC <span>YTD vs Ppto · Margen Neto Real</span></div>

  <div class="av-grid-2" style="margin-bottom:15px;align-items:start;">
    <div class="av-panel">
      <div class="av-panel__header">DETALLE YTD POR RTC <span class="av-badge">CLP · Real vs Ppto T1 y Anual</span></div>
      <table class="av-table">
        <thead><tr>
          <th scope="col" style="text-align:left;">RTC</th>
          <th scope="col">Real T1</th><th scope="col">Ppto T1</th><th scope="col" style="text-align:center;">%</th>
          <th scope="col">Abr Real</th><th scope="col">MN Real</th>
        </tr></thead>
        <tbody>
          <tr>
            <td>⭐ <strong style="color:var(--positive);">J. Caroca</strong></td>
            <td class="av-mono-sm av-text-right" style="color:var(--positive);">53,123K</td>
            <td class="av-mono-sm av-text-right">33,000K</td>
            <td class="av-text-center"><span class="pb pb-ok">161.0%</span><div class="mb"><div class="mbf" style="width:100%;background:var(--positive);"></div></div></td>
            <td class="av-mono-sm av-text-right" style="color:var(--positive);">10,171K</td>
            <td class="av-mono-sm av-text-right" style="color:var(--positive);">39.2%</td>
          </tr>
          <tr>
            <td><i class="ph-warning" style="color:var(--warning)" aria-hidden="true"></i> P. Laratro</td>
            <td class="av-mono-sm av-text-right" style="color:var(--warning);">52,893K</td>
            <td class="av-mono-sm av-text-right">54,100K</td>
            <td class="av-text-center"><span class="pb pb-am">97.8%</span><div class="mb"><div class="mbf" style="width:97.8%;background:var(--warning);"></div></div></td>
            <td class="av-mono-sm av-text-right" style="color:var(--positive);">8,305K</td>
            <td class="av-mono-sm av-text-right" style="color:var(--warning);">19.6%</td>
          </tr>
          <tr>
            <td><i class="ph-warning" style="color:var(--warning)" aria-hidden="true"></i> R. Encina</td>
            <td class="av-mono-sm av-text-right" style="color:var(--warning);">27,593K</td>
            <td class="av-mono-sm av-text-right">29,200K</td>
            <td class="av-text-center"><span class="pb pb-am">94.5%</span><div class="mb"><div class="mbf" style="width:94.5%;background:var(--warning);"></div></div></td>
            <td class="av-mono-sm av-text-right" style="color:var(--warning);">1,763K</td>
            <td class="av-mono-sm av-text-right" style="color:var(--warning);">21.9%</td>
          </tr>
          <tr>
            <td><i class="ph-circle ph-fill" style="color:var(--danger);font-size:10px" aria-hidden="true"></i> F. Velásquez</td>
            <td class="av-mono-sm av-text-right" style="color:var(--danger);">29,600K</td>
            <td class="av-mono-sm av-text-right">32,860K</td>
            <td class="av-text-center"><span class="pb pb-am">90.1%</span><div class="mb"><div class="mbf" style="width:90.1%;background:var(--danger);"></div></div></td>
            <td class="av-mono-sm av-text-right" style="color:var(--warning);">3,113K</td>
            <td class="av-mono-sm av-text-right" style="color:var(--danger);">2.8%</td>
          </tr>
          <tr>
            <td><i class="ph-x-circle" style="color:var(--danger)" aria-hidden="true"></i> I. Veverka</td>
            <td class="av-mono-sm av-text-right" style="color:var(--red2);">8,810K</td>
            <td class="av-mono-sm av-text-right">18,000K</td>
            <td class="av-text-center"><span class="pb pb-rd">48.9%</span><div class="mb"><div class="mbf" style="width:48.9%;background:var(--red2);"></div></div></td>
            <td class="av-mono-sm av-text-right">–</td>
            <td class="av-mono-sm av-text-right" style="color:var(--red2);">–28.7%</td>
          </tr>
          <tr>
            <td><i class="ph-check-circle" style="color:var(--positive)" aria-hidden="true"></i> V. Muñoz</td>
