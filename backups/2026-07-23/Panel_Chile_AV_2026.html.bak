<script src="avboard_data.js?v=20260721"></script>
<script>

/* ── AV_CHART_COLORS — FORMATO JAVIER v1.1 ─────────────────────────────── */
var G  = AV_CHART_COLORS.GREEN;        // #7AB648
var W  = AV_CHART_COLORS.WARNING;      // #F5A623 — also covers #E67E22 (R-002)
var R  = AV_CHART_COLORS.DANGER;       // #E74C3C
var B  = AV_CHART_COLORS.INFO;         // #4A9EDB
var GD = AV_CHART_COLORS.GREEN_DARK;   // #5a8f35 (panel had #5a8a35 — minor shift documented)
var TD = AV_CHART_COLORS.TEXT_DIM;     // #8fa892 exact match
/* Residual hex (no DS equiv): #080e09 borderColor-bg, #3a5a3a dark-mid-green, #C0392B red2 */
/* ── AVBOARD GUARD ─────────────────────────────────────────────────────── */
(function initFromAVBOARD(){
  function showError(msg){
    if(document.getElementById('avboard-error-banner')) return;
    var b=document.createElement('div');
    b.id='avboard-error-banner';
    b.style.cssText='position:fixed;top:0;left:0;right:0;z-index:99999;background:#E74C3C;color:#fff;padding:14px 20px;font-family:"DM Mono",monospace;font-size:13px;text-align:center;letter-spacing:.5px;box-shadow:0 2px 8px rgba(0,0,0,.4);';
    b.innerHTML='<b>⛔ ERROR AVBOARD:</b> '+msg;
    document.body.insertBefore(b,document.body.firstChild);
    console.error('[AVBOARD ERROR]',msg);
  }
  if(typeof AVBOARD==='undefined'){
    showError('avboard_data.js no cargó — datos no disponibles. Forzar recarga: Ctrl+Shift+R');
    return;
  }
  var clYTD = AVBOARD.chile&&AVBOARD.chile.ventas ? AVBOARD.chile.ventas.ytd_5m : undefined;
  var peYTD = AVBOARD.peru&&AVBOARD.peru.ventas  ? AVBOARD.peru.ventas.ytd_5m  : undefined;
  var clOK = Number.isFinite(clYTD) && clYTD > 0;
  var peOK = Number.isFinite(peYTD) && peYTD > 0;
  console.log('[AVBOARD] versión:', AVBOARD.meta&&AVBOARD.meta.version);
  console.log('[AVBOARD] Chile YTD CLP:', clYTD, clOK?'✅':'❌ inválido');
  console.log('[AVBOARD] Perú YTD USD:', peYTD, peOK?'✅':'❌ inválido');
  console.log('[AVBOARD] cortes:', AVBOARD.meta&&AVBOARD.meta.cortes);
  if(!clOK||!peOK){
    showError('AVBOARD cargó con valores inválidos — CL:'+clYTD+' PE:'+peYTD);
  }
})();
/* ── FIN GUARD ──────────────────────────────────────────────────────────── */


Chart.defaults.color = TD;
Chart.defaults.font.family = "'DM Mono', monospace";
Chart.defaults.font.size = 10;
const G=G,G2=GD,A=W,R=R,RD='#C0392B',B=B,O=W;
const GD='rgba(122,182,72,0.1)';

// RTC barras T1
new Chart(document.getElementById('cRTC'),{
  type:'bar',
  data:{
    labels:['Caroca','Laratro','Encina','Velásquez','Veverka','Muñoz'],
    datasets:[
      {label:'Ppto T1',data:[33000,54100,29200,32860,18000,3600],backgroundColor:'rgba(255,255,255,0.05)',borderColor:'rgba(255,255,255,0.15)',borderWidth:1,borderRadius:3},
      {label:'Real T1',data:[53123,52893,27593,29600,8810,4236],backgroundColor:[G,A,A,R,RD,G],borderRadius:3}
    ]
  },
  options:{responsive:true,maintainAspectRatio:false,
    plugins:{legend:{position:'top',labels:{boxWidth:10,padding:10}}},
    scales:{x:{grid:{color:GD},border:{color:GD}},y:{grid:{color:GD},border:{color:GD},ticks:{callback:v=>(v/1000).toFixed(0)+'M'}}}}
});

// Stacked mensual
new Chart(document.getElementById('cStack'),{
  type:'bar',
  data:{
    labels:['Enero','Febrero','Marzo','Abril'],
    datasets:[
      {label:'Caroca',    data:[14820,6389,31913,10171], backgroundColor:G,   borderRadius:2},
      {label:'Laratro',   data:[37028,10379,5487,8305],  backgroundColor:A,   borderRadius:2},
      {label:'Encina',    data:[13511,7263,6819,1763],    backgroundColor:G2,  borderRadius:2},
      {label:'Velásquez', data:[14491,9912,5197,3113],   backgroundColor:R,   borderRadius:2},
      {label:'Veverka',   data:[6186,944,1680,0],        backgroundColor:RD,  borderRadius:2},
      {label:'Muñoz',     data:[2196,766,1275,0],        backgroundColor:'#3a5a3a', borderRadius:2},
    ]
  },
  options:{responsive:true,maintainAspectRatio:false,
    plugins:{legend:{position:'top',labels:{boxWidth:10,padding:8}}},
    scales:{
      x:{stacked:true,grid:{color:GD},border:{color:GD}},
      y:{stacked:true,grid:{color:GD},border:{color:GD},ticks:{callback:v=>(v/1000000).toFixed(0)+'M'}}
    }}
});

// Curva acumulada 12 meses Chile
const CH_PPTO=[83558,41602,42000,46431,51000,49730,62800,76500,110800,112700,97500,86700];
const acum=arr=>arr.reduce((a,v,i)=>{a.push((a[i-1]||0)+(v||0));return a;},[]);
const pptoAc=acum(CH_PPTO);
new Chart(document.getElementById('cCurva'),{
  type:'line',
  data:{
    labels:['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'],
    datasets:[
      {label:'Ppto Acumulado',data:pptoAc,borderColor:'rgba(255,255,255,0.22)',borderDash:[6,4],borderWidth:1.5,pointRadius:3,pointBackgroundColor:'rgba(255,255,255,0.3)',tension:0.3,fill:false},
      {label:'Real Acumulado',data:[null,null,null,null,null,null,null,null,null,null,null,null],borderColor:G,backgroundColor:'rgba(122,182,72,0.08)',borderWidth:2.5,pointRadius:5,pointBackgroundColor:G,tension:0.3,fill:true},
      {type:'bar',label:'Ppto Mensual',data:CH_PPTO,backgroundColor:'rgba(255,255,255,0.04)',borderColor:'rgba(255,255,255,0.08)',borderWidth:1,borderRadius:2}
    ]
  },
  options:{responsive:true,maintainAspectRatio:false,
    plugins:{legend:{position:'top',labels:{boxWidth:10,padding:10}}},
    scales:{x:{grid:{color:GD},border:{color:GD}},y:{grid:{color:GD},border:{color:GD},ticks:{callback:v=>(v/1000).toFixed(0)+'M'}}}}
});

// CxC donut tramos
new Chart(document.getElementById('cCxC'),{
  type:'doughnut',
  data:{
    labels:['0–30d (55.6%)','31–60d (27.9%)','61–90d (10.4%)','+90d (6.1%)'],
    datasets:[{
      data:[21.9,11.0,4.1,2.4],
      backgroundColor:[G,A,O,R],
      borderColor:'#080e09',borderWidth:3
    }]
  },
  options:{responsive:true,maintainAspectRatio:false,cutout:'58%',
    plugins:{legend:{position:'bottom',labels:{boxWidth:10,padding:8}},
      tooltip:{callbacks:{label:ctx=>ctx.label+': CLP '+ctx.parsed+'M'}}}}
});

function cerrarSesion() {
  sessionStorage.removeItem('av_auth');
  sessionStorage.removeItem('av_role');
  window.location.href = 'index.html';
}

// ── AVBOARD POPULATE ─────────────────────────────────────────
(function() {
  if (typeof AVBOARD === 'undefined') {
    console.warn('[AVBOARD] avboard_data.js no disponible — usando valores estáticos');
    return;
  }
  try {
    var D = AVBOARD, cv = D.chile.ventas, cc = D.chile.cxc;

    var mesesFullCL = ['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
    var nRealCL = cv.mensual_real.filter(function(v){return v>0;}).length || 5;
    var curMesNmCL = mesesFullCL[nRealCL-1];
    var prevMesNmCL = mesesFullCL[Math.max(nRealCL-2,0)];

    function set(id, html) { var el = document.getElementById(id); if (el) el.innerHTML = html; }
    function M(n)   { return (n / 1e6).toFixed(1); }
    function K(n)   { return Math.round(n / 1000); }
    function fCLP(n){ return n.toLocaleString('es-CL'); }
    function pct(v) { return (v * 100).toFixed(1) + '%'; }
    function barColor(r, p) { return r/p >= 1 ? 'var(--positive)' : r/p >= 0.85 ? 'var(--warning)' : 'var(--danger)'; }

    var cHV = D.meta.cortes.chile_ventas;   // '11/05/2026'
    var cHC = D.meta.cortes.chile_cxc;      // '08/05/2026'
    var sHV = cHV.slice(0, 5);              // '11/05'
    var sHC = cHC.slice(0, 5);              // '08/05'

    // ── Header ───────────────────────────────────────────────────
    set('av-cl-hsub', 'Jefe Comercial · Ene–' + curMesNmCL + ' 2026 · al ' + cHV);
    set('av-cl-hdr-corte',
      '<div>Corte ventas <b>' + cHV + '</b> · CxC <b>' + cHC + '</b></div>' +
      '<div style="font-size:8px;margin-top:1px;">TC = ' + D.tc() + ' CLP/USD · Ppto anual CLP ' + cv.ppto_anual.toLocaleString('es-CL') + '</div>');

    // ── KPI 1: YTD Chile 5m ──────────────────────────────────────
    set('av-cl-kpi-ytd-lbl',   'YTD Chile ' + nRealCL + 'm');
    set('av-cl-kpi-ytd-val',   M(cv.ytd_5m) + 'M');
    set('av-cl-kpi-ytd-sub',   'CLP al ' + cHV);
    set('av-cl-kpi-ytd-badge', pct(cv.cumplimiento_5m) + ' ppto Ene-' + curMesNmCL);

    // ── KPI 2: YTD USD ───────────────────────────────────────────
    var chUsd = Math.round(cv.ytd_5m / D.tc());
    set('av-cl-kpi-usd-val',   chUsd.toLocaleString('en-US'));
    set('av-cl-kpi-usd-sub',   'CLP ' + M(cv.ytd_5m) + 'M / TC ' + D.tc());
    set('av-cl-kpi-usd-badge', 'T1: ' + pct(cv.cumplimiento_t1) + ' ✅');

    // ── KPI 3: Mes Parcial ───────────────────────────────────────
    var mayPpto = cv.mensual_ppto[nRealCL-1];
    set('av-cl-kpi-abr-lbl',   curMesNmCL + ' Parcial');
    set('av-cl-kpi-abr-val',   M(cv.mayo_parcial) + 'M');
    set('av-cl-kpi-abr-sub',   'CLP al ' + sHV + ' · ' + pct(cv.mayo_parcial / mayPpto) + ' ppto');
    var prevIdxCL = Math.max(nRealCL-2,0);
    var aprC = cv.rtc_mensual_real.caroca[prevIdxCL], aprL = cv.rtc_mensual_real.laratro[prevIdxCL];
    set('av-cl-kpi-abr-badge', prevMesNmCL + ': Caroca ' + M(aprC) + 'M · Laratro ' + M(aprL) + 'M');

    // ── KPI 4: MN Chile ──────────────────────────────────────────
    set('av-cl-kpi-mn-val', pct(cv.mn_real));

    // ── KPI 5: CxC Chile ─────────────────────────────────────────
    set('av-cl-kpi-cxc-val',   M(cc.total) + 'M');
    set('av-cl-kpi-cxc-sub',   'CLP · corte ' + cHC + ' · 2 entidades');
    set('av-cl-kpi-cxc-badge', '+90d: CLP ' + M(cc.tramos.t90) + 'M ⚠️');

    // ── Semáforo tag ─────────────────────────────────────────────
    set('av-cl-sema-tag', 'CORTE ' + sHV + ' · MN REAL');

    // ── Barras mensuales (N meses + YTD Nm) ─────────────────────
    var meses = mesesFullCL.slice(0, nRealCL);
    var barsHTML = '';
    cv.mensual_real.slice(0, nRealCL).forEach(function(real, i) {
      var ppto = cv.mensual_ppto[i];
      var ratio = real / ppto;
      var width = Math.min(ratio * 100, 100).toFixed(1);
      var pDisplay = (ratio * 100).toFixed(1) + '%';
      var color = barColor(real, ppto);
      var lbl = meses[i] + (i === nRealCL-1 ? ' (parc.)' : '');
      barsHTML += '<div class="mes-row">' +
        '<div class="mes-lbl">' + lbl + '</div>' +
        '<div class="mes-bar-wrap"><div class="mes-bar-fill" style="width:' + width + '%;background:' + color + ';"></div></div>' +
        '<div class="mes-pct" style="color:' + color + ';">' + pDisplay + '</div>' +
        '</div>';
    });
    var ytd5Pct = (cv.ytd_5m / cv.ppto_5m * 100).toFixed(1);
    var ytdColor = cv.ytd_5m >= cv.ppto_5m ? 'var(--positive)' : 'var(--warning)';
    barsHTML += '<div class="mes-row">' +
      '<div class="mes-lbl" style="font-weight:700;">YTD ' + nRealCL + 'm</div>' +
      '<div class="mes-bar-wrap"><div class="mes-bar-fill" style="width:100%;background:' + ytdColor + ';"></div></div>' +
      '<div class="mes-pct" style="color:' + ytdColor + ';font-weight:700;">' + ytd5Pct + '%</div>' +
      '</div>';
    set('av-cl-mes-container', barsHTML);

    // ── Margen strip (N meses) ────────────────────────────────────
    var stripEl = document.getElementById('av-cl-margen-strip');
    if (stripEl) stripEl.style.gridTemplateColumns = 'repeat(' + nRealCL + ',1fr)';
    var stripHTML = '';
    cv.mensual_real.slice(0, nRealCL-1).forEach(function(v, i) {
      var c = barColor(v, cv.mensual_ppto[i]);
      stripHTML += '<div class="mg-item"><div class="mg-val" style="color:' + c + ';">' + M(v) + 'M</div><div class="mg-lbl">' + meses[i] + '</div></div>';
    });
    var mayC = barColor(cv.mayo_parcial, mayPpto);
    stripHTML += '<div class="mg-item"><div class="mg-val" style="color:' + mayC + ';">' + M(cv.mayo_parcial) + 'M</div><div class="mg-lbl">' + curMesNmCL + ' *</div></div>';
    set('av-cl-margen-strip', stripHTML);

    // ── Acumulado text ────────────────────────────────────────────
    set('av-cl-mes-acum',
      'Ene-' + curMesNmCL + ' acum: CLP ' + M(cv.ytd_5m) + 'M · ' + pct(cv.cumplimiento_5m) + ' ppto ' +
      '· ' + curMesNmCL + ' parcial: CLP ' + M(cv.mayo_parcial) + 'M · TC ' + D.tc() + ' CLP/USD');

    // ── CxC sección ───────────────────────────────────────────────
    set('av-cl-cxc-sec',  'corte ' + cHC + ' · 2 entidades · CLP ' + M(cc.total) + 'M total');
    set('av-cl-cxc-ptag', 'CLP · corte ' + cHC + ' · 2 entidades');

    // ── CxC footer ────────────────────────────────────────────────
    set('av-cl-footer-txt',
      'AV Latam BI Platform · Panel Chile · Corte ventas ' + sHV +
      ' · CxC ' + sHC + '/' + cHC.slice(6) + ' · TC ' + D.tc() + ' CLP/USD · Ppto anual CLP ' + cv.ppto_anual.toLocaleString('es-CL'));

    // ── Actualizar charts ─────────────────────────────────────────
    // cStack: mensual apilado por RTC (meses completos, excluye mes parcial)
    var cStack = Chart.getChart(document.getElementById('cStack'));
    if (cStack && cv.rtc_mensual_real) {
      var rm = cv.rtc_mensual_real;
      var toK = function(v) { return v ? Math.round(v / 1000) : 0; };
      var nStackCL = Math.max(nRealCL-1, 0);
      cStack.data.labels = meses.slice(0, nStackCL);
      cStack.data.datasets[0].data = rm.caroca.slice(0,nStackCL).map(toK);
      cStack.data.datasets[1].data = rm.laratro.slice(0,nStackCL).map(toK);
      cStack.data.datasets[2].data = rm.encina.slice(0,nStackCL).map(toK);
      cStack.data.datasets[3].data = rm.velasquez.slice(0,nStackCL).map(toK);
      cStack.data.datasets[4].data = rm.veverka.slice(0,nStackCL).map(toK);
      cStack.update();
    }

    // cCurva: acumulada ppto (desde AVBOARD, reemplaza legacy 861M) + real N meses
    var cCurva = Chart.getChart(document.getElementById('cCurva'));
    if (cCurva) {
      var pptoRunCL=0, pptoAcCL=[];
      cv.mensual_ppto.forEach(function(v){pptoRunCL+=v; pptoAcCL.push(Math.round(pptoRunCL/1000));});
      cCurva.data.datasets[0].data = pptoAcCL;
      var realAcum = [null,null,null,null,null,null,null,null,null,null,null,null];
      var sum = 0;
      cv.mensual_real.slice(0, nRealCL).forEach(function(v, i) {
        sum += (v || 0);
        realAcum[i] = Math.round(sum / 1000);
      });
      cCurva.data.datasets[1].data = realAcum;
      cCurva.update();
    }

    // cCxC: donut tramos (08/05 data)
    var cCxC = Chart.getChart(document.getElementById('cCxC'));
    if (cCxC) {
      var t = cc.tramos, tp = cc.tramos_pct;
      cCxC.data.datasets[0].data = [
        parseFloat(M(t.t030)),
        parseFloat(M(t.t3160)),
        parseFloat(M(t.t6190)),
        parseFloat(M(t.t90))
      ];
      cCxC.data.labels = [
        '0–30d (' + pct(tp.t030) + ')',
        '31–60d (' + pct(tp.t3160) + ')',
        '61–90d (' + pct(tp.t6190) + ')',
        '+90d (' + pct(tp.t90) + ')'
      ];
      cCxC.update();
    }

    console.log('[AVBOARD] ✅ Panel_Chile actualizado · ' + D.meta.version);
  } catch(e) {
    console.error('[AVBOARD] Error Panel Chile:', e);
  }
})();
</script>
</body>
</html>
