<!-- TAB: VENTAS -->
<!-- ══════════════════════════════════════════════ -->
<div id="tab-ventas" class="tab-content active">

  <div class="av-panel" style="margin-bottom:16px">
    <div class="av-panel__subtitle av-mb-3">Ventas Mensuales Chile (CLP Millones) · Real 2026 vs Presupuesto 2026 · Referencia 2025</div>
    <div class="chart-canvas">
      <canvas id="chartVentas"></canvas>
    </div>
  </div>

  <div class="av-panel tbl-wrap">
    <div class="av-panel__header">
      <div class="av-panel__subtitle">Detalle mensual · Ppto 2026 vs Real 2026 · Referencia Real 2025</div>
    </div>
    <table class="av-table">
      <thead>
        <tr>
          <th scope="col">Mes</th>
          <th scope="col" class="av-text-right">Ppto 2026 (M)</th>
          <th scope="col" class="av-text-right">Real 2026 (M)</th>
          <th scope="col" class="av-text-center">% Cumpl 2026</th>
          <th scope="col" class="av-text-right">Real 2025 (M)</th>
          <th scope="col" class="av-text-center">Estado</th>
        </tr>
      </thead>
      <tbody id="tbody-ventas"></tbody>
    </table>
  </div>

  <!-- ── SEMÁFORO MENSUAL + DONUT CUMPLIMIENTO YTD ── -->
  <div class="av-grid-2" style="margin-top:16px">

    <!-- Semáforo izquierdo -->
    <div class="av-panel">
      <div class="av-panel__subtitle av-mb-3">Semáforo Mensual · Real 2026 vs Ppto 2026 · CLP</div>
      <div style="display:flex;flex-direction:column;gap:8px;margin-top:6px">
        <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(122,182,72,0.06);border-radius:6px;border-left:3px solid var(--positive)">
          <span style="font-family:'DM Mono';font-size:11px;color:var(--text-muted);width:28px">ENE</span>
          <div style="flex:1"><div class="av-progress-wrap"><div class="av-progress-fill" style="width:100%;background:var(--positive)"></div></div></div>
          <span style="font-family:'DM Mono';font-size:11px;color:var(--positive);width:44px;text-align:right">105.4%</span>
          <span style="font-size:11px;color:var(--text-dim);width:60px;text-align:right">88.2 / 83.6M</span>
          <span class="av-badge ok" style="font-size:11px;white-space:nowrap">Meta</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(245,166,35,0.05);border-radius:6px;border-left:3px solid var(--warning)">
          <span style="font-family:'DM Mono';font-size:11px;color:var(--text-muted);width:28px">FEB</span>
          <div style="flex:1"><div class="av-progress-wrap"><div class="av-progress-fill" style="width:85.7%;background:var(--warning)"></div></div></div>
          <span style="font-family:'DM Mono';font-size:11px;color:var(--warning);width:44px;text-align:right">85.7%</span>
          <span style="font-size:11px;color:var(--text-dim);width:60px;text-align:right">35.7 / 41.6M</span>
          <span class="av-badge warn" style="font-size:11px;white-space:nowrap">Bajo</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(122,182,72,0.06);border-radius:6px;border-left:3px solid var(--positive)">
          <span style="font-family:'DM Mono';font-size:11px;color:var(--text-muted);width:28px">MAR</span>
          <div style="flex:1"><div class="av-progress-wrap"><div class="av-progress-fill" style="width:100%;background:var(--positive)"></div></div></div>
          <span style="font-family:'DM Mono';font-size:11px;color:var(--positive);width:44px;text-align:right">124.7%</span>
          <span style="font-size:11px;color:var(--text-dim);width:60px;text-align:right">52.4 / 42.0M</span>
          <span class="av-badge ok" style="font-size:11px;white-space:nowrap">Meta</span>
        </div>
        <div style="display:flex;align-items:center;gap:10px;padding:8px 10px;background:rgba(231,76,60,0.05);border-radius:6px;border-left:3px solid var(--danger)">
          <span style="font-family:'DM Mono';font-size:11px;color:var(--text-muted);width:28px">ABR</span>
          <div style="flex:1"><div class="av-progress-wrap"><div class="av-progress-fill" style="width:50.4%;background:var(--danger)"></div></div></div>
          <span style="font-family:'DM Mono';font-size:11px;color:var(--danger);width:44px;text-align:right">50.4%</span>
          <span style="font-size:11px;color:var(--text-dim);width:60px;text-align:right">23.4 / 46.4M</span>
          <span class="av-badge alert" style="font-size:11px;white-space:nowrap">Parcial</span>
        </div>
      </div>
      <div style="margin-top:10px;padding:9px 12px;background:var(--surface-2);border-radius:7px;display:flex;align-items:center;justify-content:space-between">
        <span style="font-size:11px;font-weight:600;color:var(--text)" id="jch-ytd-strip-lbl">YTD —</span>
        <span style="font-family:'DM Mono';font-size:14px;color:var(--warning);font-weight:700" id="jch-ytd-strip-pct">—%</span>
        <span style="font-size:11px;color:var(--text-dim)" id="jch-ytd-strip-vals">— / —</span>
        <span class="av-badge warn" id="jch-ytd-strip-brecha">Brecha —</span>
      </div>
    </div>

    <!-- Donut cumplimiento YTD -->
    <div class="av-panel">
      <div class="av-panel__subtitle av-mb-3" id="jch-donut-title">Cumplimiento YTD · Real 2026 vs Ppto Ene–May</div>
      <div style="position:relative;height:210px">
        <canvas id="chartCumplCL"></canvas>
        <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-65%);text-align:center;pointer-events:none">
          <div id="jch-donut-pct" style="font-family:'Bebas Neue';font-size:36px;color:var(--warning);line-height:1">—%</div>
          <div style="font-size:11px;color:var(--text-muted);letter-spacing:1.5px;text-transform:uppercase;margin-top:3px">Cumpl. YTD</div>
          <div id="jch-donut-lbl" style="font-size:11px;color:var(--text-dim);margin-top:1px">—</div>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px">
        <div style="padding:8px;background:rgba(122,182,72,0.07);border-radius:5px;text-align:center">
          <div id="jch-donut-real" style="font-family:'DM Mono';font-size:14px;color:var(--positive);font-weight:700">—M</div>
          <div style="font-size:11px;color:var(--text-muted);margin-top:2px;text-transform:uppercase;letter-spacing:1px">Real 2026 YTD</div>
        </div>
        <div style="padding:8px;background:rgba(231,76,60,0.06);border-radius:5px;text-align:center">
          <div id="jch-donut-brecha" style="font-family:'DM Mono';font-size:14px;color:var(--danger);font-weight:700">—M</div>
          <div id="jch-donut-brecha-lbl" style="font-size:11px;color:var(--text-muted);margin-top:2px;text-transform:uppercase;letter-spacing:1px">Brecha vs Ppto —m</div>
        </div>
      </div>
    </div>

  </div>

</div>

