// ── TAB SWITCH ──
function switchTab(t,el){
  document.querySelectorAll('.av-tab').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c=>c.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('tab-'+t).classList.add('active');
}

// ── CHART VENTAS PRINCIPAL ──
new Chart(document.getElementById('chartVentas'),{
  type:'bar',
  data:{
    labels:LABELS,
    datasets:[
      {label:'Real 2025 (ref.)',data:real2025,backgroundColor:'rgba(122,182,72,0.15)',borderColor:'rgba(122,182,72,0.3)',borderWidth:1,borderRadius:3},
      {label:'Real 2026',data:real2026,backgroundColor:'rgba(122,182,72,0.70)',borderColor:G,borderWidth:1.5,borderRadius:3},
      {label:'Ppto 2026',data:ppto2026,type:'line',borderColor:B,borderWidth:2,pointRadius:4,
       pointBackgroundColor:B,fill:false,tension:0.3,borderDash:[5,3]}
    ]
  },
  options:{
    responsive:true,maintainAspectRatio:false,
    plugins:{
      legend:{position:'top',labels:{boxWidth:12,padding:16,usePointStyle:true}},
      tooltip:{callbacks:{label:ctx=>`${ctx.dataset.label}: CLP ${ctx.parsed.y}M`}}
    },
    scales:{
      x:{grid:{color:AV_CHART_COLORS.GRID}},
      y:{grid:{color:AV_CHART_COLORS.GRID},
        ticks:{callback:v=>v+'M'},
        title:{display:true,text:'CLP Millones',color:AV_CHART_COLORS.TEXT_MUTED,font:{size:11}}}
    }
  }
});

// ── TABLA VENTAS MENSUALES ──
(function(){
  const meses=['Enero','Febrero','Marzo','Abril','Mayo','Junio','Julio','Agosto','Septiembre','Octubre','Noviembre','Diciembre'];
  let html='';
  let tot26=0,tot25=0,totPpto=0;
  const lastDataIdxJC=real2026.reduce(function(l,v,i){return v!==null?i:l;},-1);
  const curMesNmJC=meses[lastDataIdxJC>=0?lastDataIdxJC:0];
  ppto2026.forEach((pp,i)=>{
    const v26=real2026[i], v25=real2025[i];
    const hasData=v26!==null;
    const lastDataIdx=real2026.reduce(function(l,v,i){return v!==null?i:l;},-1);
    const isPartial=i===lastDataIdx; // último mes con datos = parcial
    if(hasData) {tot26+=v26; totPpto+=pp;}
    tot25+=v25;
    const cumpl=hasData?(v26/pp*100).toFixed(1):null;
    const cumplColor=cumpl>=100?'color:var(--positive)':cumpl>=80?'color:var(--warning)':'color:var(--danger)';
    const cumplArrow=cumpl>=100?'▲':'▼';
    let estadoBadge;
    if(!hasData){estadoBadge='<span class="av-badge neutral">Sin dato</span>';}
    else if(isPartial && v26<pp){estadoBadge='<span class="av-badge warn">Abr parcial</span>';}
    else if(v26>=pp){estadoBadge='<span class="av-badge ok">≥ Ppto</span>';}
    else if(v26/pp>=0.8){estadoBadge='<span class="av-badge warn">< Ppto</span>';}
    else{estadoBadge='<span class="av-badge alert">< Ppto</span>';}
    html+=`<tr>
      <td style="font-weight:500">${meses[i]}</td>
      <td class="av-text-right av-mono-sm" style="color:var(--info)">${pp.toFixed(1)}</td>
      <td class="av-text-right av-mono-sm" style="font-weight:600">${hasData?v26.toFixed(1):'—'}</td>
      <td class="av-text-center" style="${hasData?cumplColor:'color:var(--text-muted)'};font-family:'DM Mono';font-size:11px">${hasData?`${cumplArrow} ${Math.abs(cumpl)}%`:'—'}</td>
      <td class="av-text-right av-mono-sm" style="color:var(--text-dim)">${v25.toFixed(1)}</td>
      <td class="av-text-center">${estadoBadge}</td>
    </tr>`;
  });
  const cumplTot=(tot26/totPpto*100).toFixed(1);
  html+=`<tr style="background:var(--surface-2);font-weight:700">
    <td>YTD ENE–${curMesNmJC.slice(0,3).toUpperCase()}</td>
    <td class="av-text-right av-mono-sm" style="color:var(--info)">${totPpto.toFixed(1)}</td>
    <td class="av-text-right av-mono-sm">${tot26.toFixed(1)}</td>
    <td class="av-text-center" style="color:${cumplTot>=100?'var(--positive)':'var(--warning)'};font-family:'DM Mono';font-size:11px">${cumplTot>=100?'▲':'▼'} ${Math.abs(cumplTot)}%</td>
    <td class="av-text-right av-mono-sm" style="color:var(--text-dim)">${(real2025.slice(0,lastDataIdxJC+1).reduce((a,b)=>a+b,0)).toFixed(1)}</td>
    <td class="av-text-center"><span class="av-badge warn">${curMesNmJC} parcial</span></td>
  </tr>`;
  document.getElementById('tbody-ventas').innerHTML=html;
})();

// ── TABLA VENDEDORES ──
(function(){
  let html='';
  vendedoresData.forEach((v,i)=>{
    const cumpl=v.ppto?Math.round(v.real/v.ppto*100):null;
    let sem='b-nd',semDot='alert';
    if(cumpl===null){sem='neutral';semDot='alert';}
    else if(cumpl>=90){sem='ok';semDot='ok';}
    else if(cumpl>=70){sem='warn';semDot='warn';}
    else if(cumpl>=40){sem='warn';semDot='warn';}
    else{sem='alert';semDot='alert';}
    const pptoStr=v.ppto?v.ppto.toFixed(1)+'M':'—';
    const cumplStr=cumpl?`<span class="av-badge ${sem}">${cumpl}%</span>`:'<span class="av-badge neutral">Sin ppto</span>';
    html+=`<tr>
      <td class="av-text-center av-mono-sm" style="color:var(--text-muted)">${i+1}</td>
      <td><span class="av-badge-dot ${semDot}"></span><strong>${v.nombre}</strong></td>
      <td class="av-text-right av-mono-sm" style="font-weight:600">${v.real.toFixed(1)}M</td>
      <td class="av-text-right av-mono-sm" style="color:var(--info)">${pptoStr}</td>
      <td class="av-text-center">${cumplStr}</td>
      <td class="av-text-center">
        ${v.ppto?`<div class="av-progress-wrap" style="width:80px;margin:0 auto"><div class="av-progress-fill" style="width:${Math.min(cumpl,100)}%;background:${cumpl>=90?G:cumpl>=70?A:O}"></div></div>`:'—'}
      </td>
    </tr>`;
  });
  document.getElementById('tbody-vendedores').innerHTML=html;
})();

// ── VENDEDOR SELECTOR + CHART ──
let chartVend=null;
(function(){
  const sel=document.getElementById('vend-selector');
  vendedoresData.forEach((v,i)=>{
    const btn=document.createElement('button');
    btn.className='av-sel--chip'+(i===0?' active':'');
    btn.textContent=v.corto;
    btn.onclick=()=>{
      document.querySelectorAll('.av-sel--chip').forEach(b=>b.classList.remove('active'));
      btn.classList.add('active');
      updateVendChart(i);
    };
    sel.appendChild(btn);
  });
  updateVendChart(0);
})();

function updateVendChart(idx){
  var v=vendedoresData[idx];
  var hasPending=v.avbKey===null;
  var titleNote=hasPending?' · (Real 2026: pendiente de carga)':'';
  document.getElementById('vend-chart-title').textContent=
    v.nombre+' · Real 2026 vs Real 2025 vs Ppto 2026'+titleNote;

  // Real 2026 por RTC desde AVBOARD (en M CLP), null para meses futuros
  var rtcReal2026=(v.avbKey&&avbReal2026[v.avbKey])
    ? avbReal2026[v.avbKey].map(function(val,i){
        return i<=corteIdxCL ? parseFloat((val/1e6).toFixed(1)) : null;
      })
    : Array(12).fill(null);

  // Ppto 2026 por RTC: prefer AVBOARD, fallback pptoMes (ya en M)
  var rtcPpto2026=null;
  if(v.avbKey&&avbPpto2026[v.avbKey]){
    rtcPpto2026=avbPpto2026[v.avbKey].map(function(x){return parseFloat((x/1e6).toFixed(1));});
  } else if(v.pptoMes){
    rtcPpto2026=v.pptoMes;
  }

  var datasets=[
    {label:'Real 2026',data:rtcReal2026,
     backgroundColor:'rgba(122,182,72,0.80)',borderColor:G,borderWidth:1.5,borderRadius:3,order:2},
    {label:'Real 2025',data:v.meses,
     backgroundColor:'rgba(122,182,72,0.22)',borderColor:'rgba(122,182,72,0.45)',
     borderWidth:1,borderRadius:2,order:3}
  ];
  if(rtcPpto2026){
    datasets.push({
      label:'Ppto 2026',data:rtcPpto2026,type:'line',
      borderColor:B,borderWidth:2,pointRadius:4,pointBackgroundColor:B,
      fill:false,tension:0.3,borderDash:[5,3],order:1
    });
  }
  if(chartVend){
    chartVend.data.datasets=datasets;
    chartVend.update();
  } else {
    chartVend=new Chart(document.getElementById('chartVendedor'),{
      type:'bar',
      data:{labels:LABELS,datasets:datasets},
      options:{
        responsive:true,maintainAspectRatio:false,
        plugins:{legend:{position:'top',labels:{boxWidth:12,padding:14,usePointStyle:true}},
          tooltip:{callbacks:{label:function(ctx){return ctx.dataset.label+': CLP '+ctx.parsed.y+'M';}}}},
        scales:{
          x:{grid:{color:AV_CHART_COLORS.GRID}},
          y:{grid:{color:AV_CHART_COLORS.GRID},ticks:{callback:function(v){return v+'M';}}}
        }
      }
    });
  }
  updateCuadroEjecutivo(idx);
}

// ── CUADRO EJECUTIVO ──
function updateCuadroEjecutivo(idx){
  var v=vendedoresData[idx];

  // Ppto: prefer AVBOARD rtc_mensual_ppto (pesos→M), fallback v.pptoMes (ya en M)
  var pptoArr=null;
  if(v.avbKey&&avbPpto2026[v.avbKey]){
    pptoArr=avbPpto2026[v.avbKey].map(function(x){return parseFloat((x/1e6).toFixed(1));});
  } else if(v.pptoMes){
    pptoArr=v.pptoMes.slice();
  }

  // Real 2026: solo si tiene avbKey (pesos→M)
  var realArr=null;
  if(v.avbKey&&avbReal2026[v.avbKey]){
    realArr=avbReal2026[v.avbKey].map(function(x){return parseFloat((x/1e6).toFixed(1));});
  }

  // Precomputar acumulados (meses 0..corteIdxCL)
  var pptoAcum=0,realAcum=0;
  for(var m=0;m<=corteIdxCL;m++){
    if(pptoArr&&pptoArr[m]&&pptoArr[m]>0) pptoAcum+=pptoArr[m];
    if(realArr) realAcum+=realArr[m];
  }
  pptoAcum=parseFloat(pptoAcum.toFixed(1));
  realAcum=parseFloat(realAcum.toFixed(1));
  var cumplAcum=(pptoAcum>0&&realArr)?Math.round(realAcum/pptoAcum*1000)/10:null;

  // Construir tabla completa (thead + tbody)
  var tbl='<table class="tbl-exec"><thead><tr>';
  tbl+='<th scope="col">Indicador</th>';
  for(var i=0;i<12;i++){
    var isCurr=(i===corteIdxCL);
    tbl+='<th scope="col" class="r'+(isCurr?' ce-cursor':'')+'">'+(isCurr?'▸ ':'')+LABELS[i]+'</th>';
  }
  tbl+='<th scope="col" class="av-text-right th-acum">Acum. al corte</th>';
  tbl+='</tr></thead><tbody>';

  // Fila 1: Ppto 2026
  tbl+='<tr><td style="font-weight:600;color:var(--text-dim)">Ppto 2026</td>';
  for(var j=0;j<12;j++){
    var isCurr=(j===corteIdxCL);
    var val=pptoArr?pptoArr[j]:null;
    var disp;
    if(!val||val<=0) disp='<span class="ce-nd">N/A</span>';
    else disp=val.toFixed(1)+'M';
    tbl+='<td class="r'+(isCurr?' ce-cursor':'')+'">'+disp+'</td>';
  }
  tbl+='<td class="av-text-right td-acum">'+(pptoAcum>0?pptoAcum.toFixed(1)+'M':'<span class="ce-nd">N/A</span>')+'</td></tr>';

  // Fila 2: Real 2026
  tbl+='<tr><td style="font-weight:600;color:var(--positive)">Real 2026</td>';
  for(var k=0;k<12;k++){
    var isFut=(k>corteIdxCL);
    var isCurr=(k===corteIdxCL);
    if(isFut){
      tbl+='<td class="av-text-right" style="color:var(--text-muted)">—</td>';
    } else if(!realArr){
      tbl+='<td class="r'+(isCurr?' ce-cursor':'')+'"><span class="ce-nd">Pend.</span></td>';
    } else {
      tbl+='<td class="r'+(isCurr?' ce-cursor':'')+'" style="color:var(--positive)">'+realArr[k].toFixed(1)+'M</td>';
    }
  }
  var realAcumDisp=realArr?'<span style="color:var(--positive)">'+realAcum.toFixed(1)+'M</span>':'<span class="ce-nd">Pend.</span>';
  tbl+='<td class="av-text-right td-acum">'+realAcumDisp+'</td></tr>';

  // Fila 3: Cumpl. Mensual
  tbl+='<tr><td style="font-weight:600;font-size:11px;color:var(--text-dim)">Cumpl. Mensual</td>';
  for(var n=0;n<12;n++){
    var isFut=(n>corteIdxCL);
    var isCurr=(n===corteIdxCL);
    if(isFut){
      tbl+='<td class="av-text-right" style="color:var(--text-muted)">—</td>';
    } else if(!realArr){
      tbl+='<td class="r'+(isCurr?' ce-cursor':'')+'"><span class="ce-nd">N/A</span></td>';
    } else {
      var pp=pptoArr?pptoArr[n]:null;
      if(!pp||pp<=0){
        tbl+='<td class="r'+(isCurr?' ce-cursor':'')+'"><span class="ce-nd">N/A</span></td>';
      } else {
        var pct=Math.round(realArr[n]/pp*1000)/10;
        var cc=pct>=100?'av-text-positive':(pct>=85?'av-text-warning':'av-text-danger');
        tbl+='<td class="av-text-right '+(isCurr?'ce-cursor ':'')+cc+'">'+pct+'%</td>';
      }
    }
  }
  var cumplAcumDisp;
  if(cumplAcum===null) cumplAcumDisp='<span class="ce-nd">N/A</span>';
  else{
    var cc2=cumplAcum>=100?'av-text-positive':(cumplAcum>=85?'av-text-warning':'av-text-danger');
    cumplAcumDisp='<span class="'+cc2+'">'+cumplAcum+'%</span>';
  }
  tbl+='<td class="av-text-right td-acum">'+cumplAcumDisp+'</td></tr>';

  tbl+='</tbody></table>';
  document.getElementById('tbl-exec-container').innerHTML=tbl;

  // Actualizar bloque resumen
  var set=function(id,val){var el=document.getElementById(id);if(el)el.textContent=val;};
  var setH=function(id,val){var el=document.getElementById(id);if(el)el.innerHTML=val;};
  var mesesNom=['','Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

  // Panel A — acumulado al corte
  set('res-ppto-corte',pptoAcum>0?'CLP '+pptoAcum.toFixed(1)+'M':'N/A');
  set('res-real-acum',realArr?'CLP '+realAcum.toFixed(1)+'M':'Pendiente');
  if(cumplAcum!==null){
    var cc3=cumplAcum>=100?'av-ok':(cumplAcum>=85?'av-warn':'av-alert');
    setH('res-cumpl-corte','<span class="'+cc3+'" style="font-family:\'Bebas Neue\';font-size:22px">'+cumplAcum+'%</span>');
    var barEl=document.getElementById('res-cumpl-bar');
    if(barEl){
      var fp=Math.min(cumplAcum,100);
      var bc=cumplAcum>=100?'var(--positive)':(cumplAcum>=85?'var(--warning)':'var(--danger)');
      barEl.innerHTML='<div class="av-progress-fill" style="width:'+fp+'%;background:'+bc+'"></div>';
    }
  } else {
    set('res-cumpl-corte','N/A');
    var barEl2=document.getElementById('res-cumpl-bar');
    if(barEl2) barEl2.innerHTML='<div class="av-progress-fill" style="width:0%"></div>';
  }

  // Panel B — presupuesto anual
  var pptoAnual=pptoArr?parseFloat(pptoArr.reduce(function(a,b){return a+(b&&b>0?b:0);},0).toFixed(1)):null;
  if(pptoAnual&&pptoAnual>0){
    set('res-ppto-anual','CLP '+pptoAnual.toFixed(1)+'M');
    var mRest=11-corteIdxCL;
    var corteLabel=mesesNom[corteIdxCL+1]||'';
    var pctEjec=realArr?parseFloat(realAcum/pptoAnual*100).toFixed(1)+'% ejecutado Ene–'+corteLabel:'pendiente';
    set('res-ppto-anual-sub','Ene–Dic 2026 · '+pctEjec+' · '+mRest+' meses restantes');
  } else {
    set('res-ppto-anual','N/A');
    set('res-ppto-anual-sub','Sin presupuesto asignado 2026');
  }
}

// ── TABLA CLIENTES ──
(function(){
  const cxcMap={ok:'b-ok',crit:'b-crit',warn:'b-warn'};
  const cxcLabel={ok:'Al día',crit:'<i class="ph ph-warning"></i> Mora +90d',warn:'En seguimiento'};
  let html='';
  clientesData.forEach((c,i)=>{
    html+=`<tr>
      <td class="av-text-center av-mono-sm" style="color:var(--text-muted)">${i+1}</td>
      <td style="font-weight:${i<3?'600':'400'}">${c.cli}</td>
      <td style="font-size:11px;color:var(--text-dim)">${c.rtc}</td>
      <td class="av-text-right av-mono-sm" style="font-weight:600">${c.monto.toLocaleString('es-CL')}</td>
      <td class="av-text-center"><span class="av-badge neutral">${c.pct}%</span></td>
      <td class="av-text-center"><span class="av-badge ${c.cum<=20?'b-ok':'b-nd'}">${c.cum.toFixed(1)}%</span></td>
      <td class="av-text-center"><span class="av-badge ${cxcMap[c.cxc]}">${cxcLabel[c.cxc]}</span></td>
    </tr>`;
  });
  document.getElementById('tbody-clientes').innerHTML=html;
})();

