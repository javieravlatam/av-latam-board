function iecTab(country, tab, btn) {
  ['vend','prod','cli'].forEach(t => {
    const el = document.getElementById('iec-'+country+'-'+t);
    if(el) el.style.display = t===tab ? '' : 'none';
  });
  const sel = document.getElementById('iec-sel-'+country);
  if(sel) sel.querySelectorAll('.av-sel--chip').forEach(b => b.classList.remove('active'));
  if(btn) btn.classList.add('active');
}

function cerrarSesion() {
  sessionStorage.removeItem('av_auth');
  sessionStorage.removeItem('av_role');
  window.location.href = 'index.html';
}

// ── POPULATE DESDE AVBOARD ──
(function(){
  if(typeof AVBOARD==='undefined') return;
  try{
    var cv=AVBOARD.chile.ventas, mt=AVBOARD.meta.cortes, cc=AVBOARD.chile.cxc;
    var corte=mt.chile_ventas||'';
    var ytdM=parseFloat((cv.ytd_5m/1e6).toFixed(1));
    var p5m=parseFloat((cv.ppto_5m/1e6).toFixed(1));
    var cumplPct=Math.round(cv.ytd_5m/cv.ppto_5m*100*10)/10;
    var brechaM=parseFloat((cv.ytd_5m/1e6-cv.ppto_5m/1e6).toFixed(1));

    // Header
    var meses=['','Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
    var dd=corte?corte.split('/'):[];
    var mesNom=dd.length>1?meses[parseInt(dd[1])]:'May';
    var anio=dd.length>2?dd[2].slice(2):'26';
    var nMeses=real2026.filter(function(v){return v!==null;}).length;
    var mesRango=meses[nMeses]||mesNom;
    var h=document.getElementById('jch-corte-hdr');
    if(h) h.textContent='Corte: '+mesNom+' 20'+anio+' (Ene–'+mesRango+' '+anio+')';
    var s=document.getElementById('jch-corte-sub');
    if(s) s.textContent='Real 2026 YTD · corte '+corte;

    // KPIs
    var set=function(id,txt){var el=document.getElementById(id);if(el)el.textContent=txt;};
    set('jch-kpi-ytd-lbl','Real 2026 · Acum Ene–'+mesRango);
    set('jch-kpi-ytd-val','CLP '+ytdM+'M');
    set('jch-kpi-ytd-sub',nMeses+' meses · corte '+corte);
    var cumplClass=cumplPct>=100?'av-ok':(cumplPct>=85?'av-warn':'av-alert');
    var elCumpl=document.getElementById('jch-kpi-cumpl-val');
    if(elCumpl){elCumpl.textContent=cumplPct+'%';elCumpl.className='av-kpi-lg__val '+cumplClass;}
    set('jch-kpi-cumpl-lbl','Cumplimiento vs Ppto '+nMeses+'m');
    set('jch-kpi-cumpl-sub',ytdM+'M vs ppto '+p5m+'M (Ene–'+mesRango+')');
    // Strip YTD + donut + footer
    set('jch-ytd-strip-lbl','YTD Ene–'+mesRango);
    set('jch-ytd-strip-pct',cumplPct+'%');
    set('jch-ytd-strip-vals',ytdM+'M / '+p5m+'M');
    set('jch-ytd-strip-brecha','Brecha '+(brechaM>=0?'+':'')+brechaM+'M');
    set('jch-donut-pct',cumplPct+'%');
    set('jch-donut-lbl','Ene–'+mesRango+' 2026');
    set('jch-donut-title','Cumplimiento YTD · Real 2026 vs Ppto Ene–'+mesRango);
    set('jch-donut-real',ytdM+'M');
    var absB=Math.abs(brechaM);
    set('jch-donut-brecha',(brechaM>=0?'+':'-')+absB+'M');
    set('jch-donut-brecha-lbl','Brecha vs Ppto '+nMeses+'m');
    set('jch-footer-txt','AV Latam BI Platform · Jefes País · Chile · Real Ene–'+mesRango+' 2026 (al '+corte+')');

    // chartVentas — actualizar dataset Real 2026 por si cambió
    var chV=Chart.getChart(document.getElementById('chartVentas'));
    if(chV){
      chV.data.datasets[1].data=real2026;
      chV.update('none');
    }

    // chartCumplCL — doughnut cumplimiento
    var chD=Chart.getChart(document.getElementById('chartCumplCL'));
    if(chD){
      var exceso=brechaM>0;
      var absBrecha=Math.abs(brechaM);
      chD.data.datasets[0].data=exceso?[p5m,brechaM]:[ytdM,absBrecha];
      chD.data.datasets[0].backgroundColor=exceso
        ?['rgba(122,182,72,0.70)','rgba(74,158,219,0.35)']
        :['rgba(122,182,72,0.75)','rgba(231,76,60,0.35)'];
      chD.data.datasets[0].borderColor=exceso
        ?['rgba(122,182,72,1)','rgba(74,158,219,0.5)']
        :['rgba(122,182,72,1)','rgba(231,76,60,0.5)'];
      chD.data.labels=exceso
        ?['Ppto '+nMeses+'m ('+p5m+'M)','Exceso vs Ppto ('+brechaM+'M)']
        :['Real 2026 YTD ('+ytdM+'M)','Brecha Ppto '+nMeses+'m ('+absBrecha+'M)'];
      chD.update();
    }

    // KPI: Presupuesto 2026 Anual (antes estático 861.3M)
    set('jch-kpi-ppto-val','CLP '+(cv.ppto_anual/1e6).toFixed(1)+'M');

    // KPI: Top Vendedor 2026 — calculado desde rtc_mensual_real YTD (antes estático J. CAROCA)
    if(cv.rtc_mensual_real){
      var nameMapCL={almeida:'ALMEIDA',caroca:'J. CAROCA',encina:'R. ENCINA',laratro:'P. LARATRO',munoz:'V. MUÑOZ',velasquez:'F. VELÁSQUEZ',veverka:'I. VEVERKA'};
      var totalsCL={};
      Object.keys(cv.rtc_mensual_real).forEach(function(k){
        totalsCL[k]=cv.rtc_mensual_real[k].slice(0,nMeses).reduce(function(a,b){return a+b;},0);
      });
      var topKeyCL=Object.keys(totalsCL).reduce(function(a,b){return totalsCL[a]>totalsCL[b]?a:b;});
      set('jch-kpi-top-name',nameMapCL[topKeyCL]||topKeyCL.toUpperCase());
      set('jch-kpi-top-sub','CLP '+(totalsCL[topKeyCL]/1e6).toFixed(1)+'M · '+nMeses+' meses');
    }

    // CxC tab: subtítulo + 4 tarjetas desde AVBOARD (antes estático y desactualizado)
    set('jch-cxc-sub','Cartera activa total: CLP '+(cc.total/1e6).toFixed(1)+'M');
    set('jch-cxc-030-monto',(cc.tramos.t030/1e6).toFixed(1)+'M');
    set('jch-cxc-030-detail',(cc.tramos_pct.t030*100).toFixed(1)+'% de cartera · En cobro');
    set('jch-cxc-3160-monto',(cc.tramos.t3160/1e6).toFixed(1)+'M');
    set('jch-cxc-3160-detail',(cc.tramos_pct.t3160*100).toFixed(1)+'% de cartera · Gestión activa');
    set('jch-cxc-6190-monto',(cc.tramos.t6190/1e6).toFixed(1)+'M');
    set('jch-cxc-6190-detail',(cc.tramos_pct.t6190*100).toFixed(1)+'% de cartera · Acuerdo urgente');
    set('jch-cxc-90-monto',(cc.tramos.t90/1e6).toFixed(1)+'M');
    set('jch-cxc-90-detail',(cc.tramos_pct.t90*100).toFixed(1)+'% de cartera · Acción inmediata');

    // Tabla "Clientes Críticos Chile" — reconstruida desde AVBOARD.chile.cxc.cuentas_criticas
    var tbCritCL=document.getElementById('jch-tbody-criticos');
    if(tbCritCL && cc.cuentas_criticas){
      var diasTxtCL=function(d){ var s=String(d); return /d$/.test(s) ? s : s+'d'; };
      var rowsHtmlCL='';
      var critCL=cc.cuentas_criticas.filter(function(r){return r.estado==='CRÍTICO';}).sort(function(a,b){return b.monto-a.monto;});
      var resueltoCL=cc.cuentas_criticas.filter(function(r){return r.estado!=='CRÍTICO';});
      critCL.forEach(function(r){
        var accion=r.alerta==='PRIORIDAD_MAXIMA'?'PRIORIDAD MÁXIMA':'URGENTE';
        rowsHtmlCL+='<tr>'+
          '<td><strong>'+r.cliente+'</strong></td>'+
          '<td style="font-size:11px;color:var(--text-dim)">'+r.rtc+'</td>'+
          '<td class="av-text-center"><span class="av-badge alert">'+diasTxtCL(r.dias)+'</span></td>'+
          '<td class="av-text-right av-mono-sm" style="color:var(--danger)">'+Math.round(r.monto).toLocaleString('en-US')+'</td>'+
          '<td class="av-text-center"><span class="av-badge alert">'+accion+'</span></td>'+
        '</tr>';
      });
      resueltoCL.forEach(function(r){
        rowsHtmlCL+='<tr style="background:rgba(122,182,72,0.05)">'+
          '<td><strong style="color:var(--positive)">'+r.cliente+'</strong>'+(r.nota?'<br><span style="font-size:11px;color:var(--text-muted)">'+r.nota+'</span>':'')+'</td>'+
          '<td style="font-size:11px;color:var(--text-dim)">'+r.rtc+'</td>'+
          '<td class="av-text-center">—</td>'+
          '<td class="av-text-right av-mono-sm" style="color:var(--positive)">✅ PAGADO</td>'+
          '<td class="av-text-center"><span class="av-badge ok">CERRADO</span></td>'+
        '</tr>';
      });
      var totalCritMonto=critCL.reduce(function(a,r){return a+r.monto;},0);
      rowsHtmlCL+='<tr style="background:var(--surface-2)">'+
        '<td colspan="3" style="font-weight:600">Total +90d cartera</td>'+
        '<td class="av-text-right av-mono-sm" style="color:var(--danger);font-weight:700">'+Math.round(totalCritMonto).toLocaleString('en-US')+'</td>'+
        '<td></td>'+
      '</tr>';
      tbCritCL.innerHTML=rowsHtmlCL;
    }
  }catch(e){console.warn('[AVBOARD][JCH]',e);}
})();
</script>
</body>
</html>
