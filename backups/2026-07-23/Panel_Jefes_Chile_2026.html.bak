<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Panel Jefes · Chile 2026 · AV Latam</title>
<!-- FORMATO JAVIER v1.1 Phosphor Icons Regular -->
<link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/regular/style.css">
<!-- FORMATO JAVIER v1.1 Design System (orden obligatorio) -->
<link rel="stylesheet" href="design-system/formato-javier-tokens.css">
<link rel="stylesheet" href="design-system/formato-javier-base.css">
<link rel="stylesheet" href="design-system/formato-javier-components.css">
<link rel="stylesheet" href="design-system/formato-javier-executive.css">
<link rel="stylesheet" href="design-system/formato-javier-motion.css">
<link rel="stylesheet" href="design-system/formato-javier-utilities.css">
<link rel="stylesheet" href="design-system/domains/formato-javier-board.css">
<script src="avboard_data.js?v=20260722"></script>
<script src="js/av-chart-colors.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<style>
/* =================================================================
   PANEL_JEFES_CHILE_2026 - CSS RESIDUAL - FORMATO JAVIER v1.1
   DEUDA v1.2 (Opcion B aprobada 2026-07-22):
     .mes-table | .cxc-grid/.cxc-card | .pricing-cards/.pc | .tbl-exec
   R-002: --orange -> --warning (tramo CxC 61-90d pierde diferenciacion visual)
   REGLA: no aumentar este bloque. Evaluar candidatos v1.2 tras 2do panel.
   ================================================================= */

/* Tab funcional */
.tab-content{display:none}
.tab-content.active{display:block}

/* Seccion interior (border-left verde, sin equiv DS v1.1) */
.sec{font-family:var(--font-display);font-size:13px;letter-spacing:3px;
  color:var(--domain-accent);border-left:3px solid var(--domain-accent);
  padding-left:10px;margin:22px 0 14px;display:flex;align-items:center;gap:10px}
.sec span{font-family:var(--font-mono);font-size:11px;color:var(--text-muted);
  font-weight:400;letter-spacing:0}

/* tbl-wrap: av-panel + overflow:hidden (para corner-clip de tablas) */
.tbl-wrap{overflow:hidden}


/* Canvas heights */
.chart-canvas{height:280px;position:relative}
.chart-canvas-sm{height:220px;position:relative}

/* Footer */
.footer{text-align:center;padding:20px 32px;font-size:11px;color:var(--text-muted);
  border-top:1px solid var(--border-dim);margin-top:20px;
  display:flex;justify-content:space-between;align-items:center}

/* == v1.2 DEBT: Grilla mensual 12 col == */

/* == v1.2 DEBT: CxC tramo cards (61-90d = --warning per R-002) == */
.cxc-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
.cxc-card{border-radius:var(--component-radius);padding:14px 16px}
.cxc-card .tramo{font-size:11px;text-transform:uppercase;letter-spacing:1.5px;font-weight:700;margin-bottom:6px}
.cxc-card .monto{font-family:var(--font-display);font-size:22px;line-height:1;margin-bottom:4px}
.cxc-card .detail{font-size:11px;color:var(--text-dim)}

/* == v1.2 DEBT: IEC pricing cards == */
.pc{background:var(--surface-2);border:1px solid;border-radius:var(--component-radius);padding:14px}
.pc-icon{font-size:20px;margin-bottom:8px}
.pc-val{font-family:var(--font-display);font-size:26px;line-height:1;margin-bottom:4px}
.pc-lbl{font-size:11px;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px}

/* == v1.2 DEBT: Tabla ejecutiva scrollable con sticky primera col == */
.exec-wrap{background:var(--surface);border:1px solid var(--border);
  border-radius:var(--panel-radius);overflow:hidden;margin-top:4px}
.exec-scroll{overflow-x:auto;-webkit-overflow-scrolling:touch}
table.tbl-exec{width:max-content;min-width:100%;border-collapse:collapse;font-size:11px}
table.tbl-exec th{padding:8px 10px;text-align:right;font-size:11px;text-transform:uppercase;
  letter-spacing:1px;color:var(--text-muted);background:var(--surface-2);font-weight:600;
  border-bottom:1px solid var(--border);white-space:nowrap}
table.tbl-exec td{padding:7px 10px;border-bottom:1px solid rgba(122,182,72,0.06);white-space:nowrap}
table.tbl-exec tr:last-child td{border-bottom:none}
table.tbl-exec th:first-child{text-align:left;min-width:130px;
  position:sticky;left:0;z-index:3;background:var(--surface-2)}
table.tbl-exec td:first-child{text-align:left;
  position:sticky;left:0;z-index:2;background:var(--surface)}
table.tbl-exec th.th-acum{border-left:2px solid rgba(122,182,72,0.35);background:rgba(122,182,72,0.04)}
table.tbl-exec td.td-acum{border-left:2px solid rgba(122,182,72,0.35);
  background:rgba(122,182,72,0.04);font-weight:700}
.ce-cursor{background:rgba(122,182,72,0.07)!important;
  border-left:1px solid rgba(122,182,72,0.22)!important;
  border-right:1px solid rgba(122,182,72,0.22)!important}
.ce-nd{color:var(--text-muted);font-size:11px;font-style:italic}
</style>
</head>
