/* ── AVBOARD GUARD ─────────────────────────────────────────────────────── */
(function initFromAVBOARD(){
  function showError(msg){
    if(document.getElementById('avboard-error-banner')) return;
    var b=document.createElement('div');
    b.id='avboard-error-banner';
    b.style.cssText='position:fixed;top:0;left:0;right:0;z-index:99999;background:#E74C3C;color:#fff;padding:14px 20px;font-family:"DM Mono",monospace;font-size:13px;text-align:center;letter-spacing:.5px;box-shadow:0 2px 8px rgba(0,0,0,.4);';
    b.innerHTML='<b>⛔ ERROR AVBOARD:</b> '+msg;
    document.body.insertBefore(b,document.body.firstChild);
    console.error('[AVBOARD ERROR]',msg);
  }
  if(typeof AVBOARD==='undefined'){
    showError('avboard_data.js no cargó — datos no disponibles. Forzar recarga: Ctrl+Shift+R');
    return;
  }
  var clYTD = AVBOARD.chile&&AVBOARD.chile.ventas ? AVBOARD.chile.ventas.ytd_5m : undefined;
  var peYTD = AVBOARD.peru&&AVBOARD.peru.ventas  ? AVBOARD.peru.ventas.ytd_5m  : undefined;
  var clOK = Number.isFinite(clYTD) && clYTD > 0;
  var peOK = Number.isFinite(peYTD) && peYTD > 0;
  console.log('[AVBOARD] versión:', AVBOARD.meta&&AVBOARD.meta.version);
  console.log('[AVBOARD] Chile YTD CLP:', clYTD, clOK?'✅':'❌ inválido');
  console.log('[AVBOARD] Perú YTD USD:', peYTD, peOK?'✅':'❌ inválido');
  console.log('[AVBOARD] cortes:', AVBOARD.meta&&AVBOARD.meta.cortes);
  if(!clOK||!peOK){
    showError('AVBOARD cargó con valores inválidos — CL:'+clYTD+' PE:'+peYTD);
  }
})();
/* ── FIN GUARD ──────────────────────────────────────────────────────────── */


