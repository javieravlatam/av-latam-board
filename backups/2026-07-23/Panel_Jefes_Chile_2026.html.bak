        </div>
      </div>
      <div class="av-progress-wrap" style="margin-top:10px" id="res-cumpl-bar">
        <div class="av-progress-fill" style="width:0%"></div>
      </div>
    </div>
    <div class="av-panel">
      <div class="av-label">B · Presupuesto Anual</div>
