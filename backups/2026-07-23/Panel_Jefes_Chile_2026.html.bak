  ? AVBOARD.chile.ventas.mensual_ppto.map(function(v){return parseFloat((v/1e6).toFixed(1));})
  : [83.6,41.6,42.0,46.4,51.0,49.7,62.8,76.5,110.8,112.7,97.5,86.7];
var real2026=(typeof AVBOARD!=='undefined')
  ? AVBOARD.chile.ventas.mensual_real.map(function(v){return v>0?parseFloat((v/1e6).toFixed(1)):null;})
  : Array(12).fill(null);
var avbReal2026=(typeof AVBOARD!=='undefined'&&AVBOARD.chile&&AVBOARD.chile.ventas&&AVBOARD.chile.ventas.rtc_mensual_real)
  ?AVBOARD.chile.ventas.rtc_mensual_real:{};
var avbPpto2026=(typeof AVBOARD!=='undefined'&&AVBOARD.chile&&AVBOARD.chile.ventas&&AVBOARD.chile.ventas.rtc_mensual_ppto)
  ?AVBOARD.chile.ventas.rtc_mensual_ppto:{};
var corteIdxCL=(function(){
  try{var s=AVBOARD.meta.cortes.chile_ventas||'';var p=s.split('/');
    return p.length>=2?parseInt(p[1],10)-1:5;}catch(e){return 5;}})();

