<!-- TAB: CxC & EFICIENCIA -->
<!-- ══════════════════════════════════════════════ -->
<div id="tab-cxc" class="tab-content">

  <div class="sec">Cobranzas Chile · Corte 17/05/2026 <span id="jch-cxc-sub">Cartera activa total: CLP 162.2M</span></div>

  <div class="cxc-grid" style="margin-bottom:20px">
    <div class="cxc-card" style="background:rgba(122,182,72,0.07);border:1px solid rgba(122,182,72,0.25)">
      <div class="tramo" style="color:var(--positive)">0–30d Normal</div>
      <div class="monto" style="color:var(--positive)" id="jch-cxc-030-monto">98.5M</div>
      <div class="detail" id="jch-cxc-030-detail">73.1% de cartera · En cobro</div>
    </div>
    <div class="cxc-card" style="background:rgba(245,166,35,0.07);border:1px solid rgba(245,166,35,0.25)">
      <div class="tramo" style="color:var(--warning)">31–60d Alerta</div>
      <div class="monto" style="color:var(--warning)" id="jch-cxc-3160-monto">13.0M</div>
      <div class="detail" id="jch-cxc-3160-detail">9.6% de cartera · Gestión activa</div>
    </div>
    <div class="cxc-card" style="background:rgba(230,126,34,0.07);border:1px solid rgba(230,126,34,0.25)">
      <div class="tramo" style="color:var(--warning)">61–90d Riesgo</div>
      <div class="monto" style="color:var(--warning)" id="jch-cxc-6190-monto">7.4M</div>
