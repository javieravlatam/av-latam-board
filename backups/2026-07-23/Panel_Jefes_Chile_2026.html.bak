</div>

<div class="av-page">

<!-- KPI BANNER -->
<div class="av-exec-summary">
  <div class="av-kpi-lg">
    <div class="av-kpi-lg__label" id="jch-kpi-ytd-lbl">Real 2026 · Acum Ene–May</div>
    <div class="av-kpi-lg__val av-ok" id="jch-kpi-ytd-val">CLP 342.9M</div>
    <div class="av-kpi-lg__sub" id="jch-kpi-ytd-sub">5 meses · corte 18/05/2026</div>
  </div>
  <div class="av-kpi-lg">
    <div class="av-kpi-lg__label" id="jch-kpi-cumpl-lbl">Cumplimiento vs Ppto 5m</div>
    <div class="av-kpi-lg__val av-ok" id="jch-kpi-cumpl-val">129.6%</div>
    <div class="av-kpi-lg__sub" id="jch-kpi-cumpl-sub">342.9M vs ppto 264.6M (Ene–May)</div>
  </div>
  <div class="av-kpi-lg">
    <div class="av-kpi-lg__label">Presupuesto 2026 · Anual</div>
    <div class="av-kpi-lg__val av-text-info" id="jch-kpi-ppto-val">CLP 861.3M</div>
    <div class="av-kpi-lg__sub">Meta anual · 6 RTCs activos</div>
  </div>
  <div class="av-kpi-lg">
    <div class="av-kpi-lg__label">Top Vendedor 2026</div>
    <div class="av-kpi-lg__val av-ok av-display-sm" id="jch-kpi-top-name">J. CAROCA</div>
    <div class="av-kpi-lg__sub" id="jch-kpi-top-sub">CLP 63.3M · 4 meses</div>
  </div>
  <div class="av-kpi-lg">
    <div class="av-kpi-lg__label">IEC 2026 YTD</div>
    <div class="av-kpi-lg__val av-alert">43.1%</div>
    <div class="av-kpi-lg__sub">Eficiencia vs precio piso propuesto</div>
  </div>
</div>

<!-- TABS -->
<div class="av-nav-tabs">
  <button class="av-tab active" onclick="switchTab('ventas',this)"><i class="ph ph-chart-line"></i> Ventas & Presupuesto</button>
  <button class="av-tab" onclick="switchTab('vendedores',this)"><i class="ph ph-user"></i> Vendedores</button>
  <button class="av-tab" onclick="switchTab('clientes',this)"><i class="ph ph-buildings"></i> Clientes</button>
  <button class="av-tab" onclick="switchTab('cxc',this)"><i class="ph ph-credit-card"></i> CxC & Eficiencia</button>
</div>

